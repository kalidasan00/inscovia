// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InstituteCategory {
  SCHOOL_TUITION
  STUDY_ABROAD
  LANGUAGES
  IT_TECHNOLOGY
  DESIGN_CREATIVE
  MANAGEMENT
  SKILL_DEVELOPMENT
  EXAM_COACHING
}

enum CenterCategory {
  SCHOOL_TUITION
  STUDY_ABROAD
  LANGUAGES
  IT_TECHNOLOGY
  DESIGN_CREATIVE
  MANAGEMENT
  SKILL_DEVELOPMENT
  EXAM_COACHING
}

enum UserRole {
  ADMIN
  USER
  INSTITUTE // ✅ kept for migration — removed after InstituteUser table dropped
}

enum OrgRole {
  OWNER
  MANAGER
  STAFF
}

enum OrgMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum OrgInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum TeachingMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ALERT
}

enum BannerPlacement {
  HERO
  FEATURED
}

// ─── Unified User Model ──────────────────────────────────────────────────────

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  phone    String
  password String

  gender     String?
  role       UserRole @default(USER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgMemberships OrgMember[]
  notifications  Notification[]

  @@index([email])
  @@index([role])
}

// ─── Organization ────────────────────────────────────────────────────────────

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  primaryCategory     InstituteCategory
  secondaryCategories InstituteCategory[] @default([])
  teachingMode        TeachingMode        @default(OFFLINE)

  state    String
  district String
  city     String
  location String

  latitude  Float?
  longitude Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members OrgMember[]
  centers Center[]
  invites OrgInvite[]
  banners Banner[]

  @@index([slug])
  @@index([city])
  @@index([state])
  @@index([primaryCategory])
}

// ─── OrgMember ───────────────────────────────────────────────────────────────

model OrgMember {
  id     String          @id @default(cuid())
  role   OrgRole         @default(STAFF)
  status OrgMemberStatus @default(ACTIVE)

  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
  @@index([role])
  @@index([status])
}

// ─── OrgInvite ───────────────────────────────────────────────────────────────

model OrgInvite {
  id     String          @id @default(cuid())
  email  String
  role   OrgRole         @default(STAFF)
  token  String          @unique
  status OrgInviteStatus @default(PENDING)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@index([orgId])
  @@index([status])
}

// ─── Center ──────────────────────────────────────────────────────────────────

model Center {
  id   String        @id @default(cuid())
  slug String        @unique
  name String

  primaryCategory     CenterCategory
  secondaryCategories CenterCategory[] @default([])
  teachingMode        TeachingMode

  state    String
  district String
  city     String
  location String

  latitude  Float?
  longitude Float?

  rating  Float    @default(0)
  courses String[]

  courseDetails Json? @default("[]")

  image   String?
  logo    String?
  gallery String[] @default([])

  description String @db.Text

  website  String?
  whatsapp String?
  phone    String?
  email    String?

  facebook  String?
  instagram String?
  linkedin  String?

  countries       String[] @default([])
  services        String[] @default([])
  topUniversities String[] @default([])
  avgScholarship  String?
  successRate     String?
  studentsPlaced  Int?

  // ✅ NEW: belongs to Organization
  orgId String?
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // ✅ KEPT for migration — remove after migration complete
  userId String?

  reviews Review[]
  banners Banner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([state, district, city])
  @@index([orgId])
  @@index([userId])
  @@index([primaryCategory])
  @@index([teachingMode])
  @@index([city])
  @@index([state])
  @@index([rating])
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id        String @id @default(cuid())
  userName  String
  userEmail String
  rating    Int
  comment   String @db.Text

  centerId String
  center   Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@unique([userEmail, centerId])
  @@index([rating])
  @@index([createdAt])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  title   String
  message String           @db.Text
  type    NotificationType @default(INFO)
  isRead  Boolean          @default(false)

  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── PreviousYearPaper ───────────────────────────────────────────────────────

model PreviousYearPaper {
  id           String  @id @default(cuid())
  slug         String  @unique
  examName     String
  examCategory String
  subject      String?
  year         Int
  shift        String?
  language     String  @default("English")
  pdfUrl       String
  fileSize     String?
  downloads    Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([examName])
  @@index([examCategory])
  @@index([year])
  @@index([isActive])
}

// ─── AptitudeQuestion ────────────────────────────────────────────────────────

model AptitudeQuestion {
  id          String     @id @default(cuid())
  question    String     @db.Text
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  answer      String
  explanation String     @db.Text
  topic       String
  subtopic    String
  difficulty  Difficulty @default(EASY)
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([topic])
  @@index([subtopic])
  @@index([difficulty])
  @@index([isActive])
  @@index([topic, subtopic])
  @@index([topic, difficulty])
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  city      String?
  category  String?
  source    String   @default("browse")
  createdAt DateTime @default(now())

  @@index([query])
  @@index([city])
  @@index([category])
  @@index([createdAt])
}

model CenterView {
  id         String   @id @default(cuid())
  centerId   String
  centerName String
  city       String?
  category   String?
  createdAt  DateTime @default(now())

  @@index([centerId])
  @@index([city])
  @@index([category])
  @@index([createdAt])
}

// ─── Banner ──────────────────────────────────────────────────────────────────

model Banner {
  id       String          @id @default(cuid())
  centerId String
  center   Center          @relation(fields: [centerId], references: [id], onDelete: Cascade)

  orgId String?
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title      String
  tagline    String?
  imageUrl   String?
  ctaText    String          @default("View Institute")
  placement  BannerPlacement
  duration   Int
  isActive   Boolean         @default(false)
  startDate  DateTime?
  endDate    DateTime?
  pricePaise Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([centerId])
  @@index([orgId])
  @@index([placement])
  @@index([isActive])
  @@index([endDate])
  @@index([placement, isActive])
}

model BannerWaitlist {
  id         String          @id @default(cuid())
  centerId   String
  centerName String
  placement  BannerPlacement
  duration   Int
  email      String

  createdAt DateTime @default(now())

  @@index([placement])
  @@index([centerId])
}

// ─── InstituteUser (kept for migration only) ─────────────────────────────────

model InstituteUser {
  id       String   @id @default(cuid())
  email    String   @unique
  password String

  instituteName       String
  phone               String
  primaryCategory     InstituteCategory
  secondaryCategories InstituteCategory[] @default([])
  teachingMode        TeachingMode

  state    String
  district String
  city     String
  location String

  latitude  Float?
  longitude Float?

  role       UserRole @default(INSTITUTE)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
